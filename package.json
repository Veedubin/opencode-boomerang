{
  "name": "@veedubin/boomerang-v2",
  "version": "4.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Veedubin/opencode-boomerang.git"
  },
  "homepage": "https://github.com/Veedubin/opencode-boomerang#readme",
  "bugs": {
    "url": "https://github.com/Veedubin/opencode-boomerang/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "boomerang-v2": "./dist/index.js",
    "boomerang-install": "./scripts/install-agents.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "verify-version": "node scripts/verify-version-sync.js",
    "migrate-memory": "tsx scripts/migrate-lancedb-to-qdrant.ts",
    "qdrant:start": "docker-compose up -d qdrant",
    "qdrant:stop": "docker-compose stop qdrant",
    "qdrant:logs": "docker-compose logs -f qdrant",
    "qdrant:status": "docker-compose ps qdrant"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@veedubin/super-memory-ts": "^2.3.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
