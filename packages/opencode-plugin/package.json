{
  "name": "@veedubin/boomerang-v2",
  "version": "4.0.0",
  "description": "Intelligent routing and context building plugin for OpenCode. Provides multi-agent orchestration with rich Context Packages.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "boomerang": "bin/boomerang.js"
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/",
    "agents/",
    "skills/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "multi-agent",
    "orchestration",
    "boomerang-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veedubin/opencode-boomerang.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "^1.4.3",
    "@opencode-ai/sdk": "^1.4.6",
    "@veedubin/super-memory-ts": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
